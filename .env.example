# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Weights & Biases API key (from https://wandb.ai/authorize)
WANDB_API_KEY=your_wandb_api_key_here

# Email notifications (email_callback.py)
EMAIL_SENDER=your_sender@gmail.com
EMAIL_RECIPIENT=your_recipient@gmail.com
EMAIL_APP_PASSWORD=your_app_password_here

# Google Drive archive links (provision_runpod.sh)
# These are YOUR OWN private archives — not for data redistribution.
# Create your own after downloading data from DrivenData.
DATA_LINK1=<your_archive_url>
DATA_LINK2=<your_archive_url>
DATA_LINK3=<your_archive_url>
